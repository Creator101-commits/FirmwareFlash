{
  "id": "temperature-logger",
  "name": "Temperature Logger",
  "description": "Read temperature and humidity from a DHT22 and print to serial.",
  "category": "Sensors",
  "compatibleBoards": ["Arduino Uno", "ESP32", "CH340 (common ESP32 clone)"],
  "requiredLibraries": ["DHT", "Adafruit_Sensor"],
  "params": [
    { "key": "pin", "label": "DHT22 Data Pin", "type": "number", "default": "2" },
    { "key": "logInterval", "label": "Log interval (ms)", "type": "number", "default": "2000" }
  ],
  "flashBytes": 5200,
  "ramBytes": 200,
  "wiringDiagram": [
    { "component": "DHT22", "boardPin": "D2", "componentPin": "DATA" },
    { "component": "DHT22", "boardPin": "5V", "componentPin": "VCC" },
    { "component": "DHT22", "boardPin": "GND", "componentPin": "GND" },
    { "component": "10kΩ Resistor", "boardPin": "5V", "componentPin": "Pull-up on DATA" }
  ],
  "setupCode": "  Serial.begin(115200);\n  dht.begin();",
  "loopCode": "  float h = dht.readHumidity();\n  float t = dht.readTemperature();\n  if (!isnan(h) && !isnan(t)) {\n    Serial.print(\"Temp: \");\n    Serial.print(t);\n    Serial.print(\" C  Humidity: \");\n    Serial.print(h);\n    Serial.println(\"%\");\n  }\n  delay({{logInterval}});"
}
